{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/entrypoint-codex.js --hook check-git-push",
            "commandWindows": "node ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/entrypoint-codex.js --hook check-git-push",
            "timeout": 1
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/entrypoint-codex.js --hook check-commit-message",
            "commandWindows": "node ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/entrypoint-codex.js --hook check-commit-message",
            "timeout": 1
          }
        ]
      }
    ]
  }
}
