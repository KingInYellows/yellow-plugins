{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "yellow-debt",
  "version": "1.6.6",
  "description": "Technical debt audit and remediation with parallel scanner agents. Use when you need to assess codebase health, identify AI-generated debt patterns, prioritize findings, and systematically remediate technical debt.",
  "author": {
    "name": "KingInYellows",
    "url": "https://github.com/KingInYellows"
  },
  "homepage": "https://github.com/KingInYellows/yellow-plugins#yellow-debt",
  "repository": "https://github.com/KingInYellows/yellow-plugins",
  "license": "MIT",
  "keywords": [
    "code-quality",
    "scanner"
  ],
  "outputStyles": "./output-styles",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-start.sh",
            "timeout": 3
          }
        ]
      }
    ]
  },
  "dependencies": [
    {
      "name": "yellow-linear",
      "version": "*",
      "optional": true,
      "reason": "debt:sync uses mcp__plugin_yellow-linear_linear__create_issue"
    }
  ]
}
